
<div class="change-password-page">

  <div class="change-password-header">
    {{#if forced}}
    <div class="forced-change-banner">
      <i data-lucide="shield-alert"></i>
      You must change your password before continuing
    </div>
    {{else}}
    <h1 class="page-title">Change Password</h1>
    <p class="page-sub">Update your login password</p>
    {{/if}}
  </div>

  {{#if error}}
  <div class="settings-alert alert-error">
    <i data-lucide="triangle-alert"></i>
    <span>{{error}}</span>
  </div>
  {{/if}}

  {{#if success}}
  <div class="settings-alert alert-success">
    <i data-lucide="check-circle"></i>
    <span>{{success}}</span>
  </div>
  {{/if}}

  <div class="settings-card change-password-card">
    <form method="POST" action="/settings/change-password" class="auth-form">

      <div class="auth-field">
        <label class="auth-label" for="currentPassword">Current Password</label>
        <div class="auth-input-wrap">
          <i data-lucide="lock"></i>
          <input
            type="password"
            id="currentPassword"
            name="currentPassword"
            placeholder="Your current password"
            required
            autofocus
          />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="newPassword">New Password</label>
        <div class="auth-input-wrap">
          <i data-lucide="lock-keyhole"></i>
          <input
            type="password"
            id="newPassword"
            name="newPassword"
            placeholder="Min. 8 characters"
            required
            minlength="8"
          />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-label" for="confirmPassword">Confirm New Password</label>
        <div class="auth-input-wrap">
          <i data-lucide="lock-keyhole"></i>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="Repeat new password"
            required
          />
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="auth-btn">
          <i data-lucide="check"></i>
          Update Password
        </button>
        {{#unless forced}}
        <a href="/settings" class="btn btn-ghost">Cancel</a>
        {{/unless}}
      </div>

    </form>
  </div>

</div>