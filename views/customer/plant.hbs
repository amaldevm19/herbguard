<!-- Hero section -->
<div class="cp-hero">
  {{#if primaryImage}}
  <div class="cp-hero-image">
    <img src="/uploads/plants/{{plant.pot_id}}/{{primaryImage.filename}}"
      alt="{{plant.plant_name}}"/>
  </div>
  {{else}}
  <div class="cp-hero-emoji">{{plant.emoji}}</div>
  {{/if}}

  <div class="cp-hero-info">
    <div class="cp-pot-id">{{plant.pot_id}}</div>
    <h1 class="cp-plant-name">{{plant.plant_name}}</h1>
    <p class="cp-species">
      <em>{{plant.species}}</em>
      {{#if plant.family}}· {{plant.family}}{{/if}}
    </p>
    <div class="cp-meta-row">
      {{#if plant.location}}
      <div class="cp-location">
        <i data-lucide="map-pin"></i>
        {{plant.location}}
      </div>
      {{/if}}
      {{#if sensor.hasData}}
      <div class="cp-last-updated">
        <i data-lucide="clock"></i>
        {{timeAgo lastUpdated}}
      </div>
      {{/if}}
    </div>

    <!-- Health indicator -->
    {{#if sensor.hasData}}
    <div class="cp-health-row">
      <div class="cp-sensor-item">
        <i data-lucide="droplets"></i>
        <span>{{toFixed sensor.moisture 0}}%</span>
        <span class="cp-sensor-label">Moisture</span>
      </div>
      <div class="cp-sensor-item">
        <i data-lucide="thermometer"></i>
        <span>{{toFixed sensor.airTemp 1}}°C</span>
        <span class="cp-sensor-label">Temp</span>
      </div>
      <div class="cp-sensor-item">
        <i data-lucide="wind"></i>
        <span>{{toFixed sensor.humidity 0}}%</span>
        <span class="cp-sensor-label">Humidity</span>
      </div>
      <div class="cp-sensor-item">
        <i data-lucide="flask-conical"></i>
        <span>{{toFixed sensor.ph 1}}</span>
        <span class="cp-sensor-label">pH</span>
      </div>
    </div>

    {{else}}
    <div class="cp-no-sensor">
      <i data-lucide="wifi-off"></i>
      No sensor data available
    </div>
    {{/if}}
  </div>
</div>

<!-- Description -->
{{#if plant.description}}
<div class="cp-section">
  <p class="cp-description">{{plant.description}}</p>
</div>
{{/if}}

<!-- Uses -->
{{#if plant.uses.length}}
<div class="cp-section">
  <h2 class="cp-section-title">
    <i data-lucide="heart"></i> Uses & Benefits
  </h2>
  <div class="cp-uses-grid">
    {{#each plant.uses}}
    <div class="cp-use-card">
      <i data-lucide="check-circle"></i>
      <span>{{this}}</span>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Image gallery -->
{{#if images.length}}
<div class="cp-section">
  <h2 class="cp-section-title">
    <i data-lucide="image"></i> Gallery
  </h2>
  <div class="cp-gallery">
    {{#each images}}
    <div class="cp-gallery-item">
      <img
        src="/uploads/plants/{{../plant.pot_id}}/{{filename}}"
        alt="{{caption}}"
        onclick="openLightbox(this.src)"
      />
      {{#if caption}}
      <p class="cp-gallery-caption">{{caption}}</p>
      {{/if}}
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- Optimal conditions -->
<div class="cp-section">
  <h2 class="cp-section-title">
    <i data-lucide="sliders-horizontal"></i> Ideal Growing Conditions
  </h2>
  <div class="cp-conditions-grid">
    <div class="cp-condition">
      <div class="cp-condition-icon" style="color:var(--blue)">
        <i data-lucide="droplets"></i>
      </div>
      <div class="cp-condition-label">Soil Moisture</div>
      <div class="cp-condition-val">
        {{plant.optimalMoisture.[0]}}–{{plant.optimalMoisture.[1]}}%
      </div>
    </div>
    <div class="cp-condition">
      <div class="cp-condition-icon" style="color:var(--amber)">
        <i data-lucide="thermometer"></i>
      </div>
      <div class="cp-condition-label">Temperature</div>
      <div class="cp-condition-val">
        {{plant.optimalTemp.[0]}}–{{plant.optimalTemp.[1]}}°C
      </div>
    </div>
    <div class="cp-condition">
      <div class="cp-condition-icon" style="color:var(--purple)">
        <i data-lucide="flask-conical"></i>
      </div>
      <div class="cp-condition-label">pH Level</div>
      <div class="cp-condition-val">
        {{plant.optimalPh.[0]}}–{{plant.optimalPh.[1]}}
      </div>
    </div>
  </div>
</div>

{{#if sensor.hasData}}
<div class="cp-section">
  <h2 class="cp-section-title">
    <i data-lucide="history"></i> Recent Readings
  </h2>
  <div class="cp-table-wrap">
    <table class="cp-data-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Moisture</th>
          <th>Air Temp</th>
          <th>Humidity</th>
          <th>pH</th>
          <th>Light</th>
        </tr>
      </thead>
      <tbody id="cp-history-tbody">
        <!-- Populated by customer.js -->
      </tbody>
    </table>
  </div>
</div>
{{/if}}

<!-- Lightbox -->
<div class="cp-lightbox" id="cp-lightbox" onclick="closeLightbox()">
  <img id="cp-lightbox-img" src="" alt=""/>
</div>

<!-- Pass pot ID to JS for visited history -->
<script>
  const CURRENT_POT = {
    potId:     '{{plant.pot_id}}',
    plantName: '{{plant.plant_name}}',
    emoji:     '{{plant.emoji}}'
  };
  const CP_HISTORY = {{{historyJSON}}};
  
</script>